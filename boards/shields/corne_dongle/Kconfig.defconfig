if SHIELD_CORNE_DONGLE

config ZMK_KEYBOARD_NAME
    default "Corne"

config ZMK_SPLIT_ROLE_CENTRAL
    default y

config ZMK_SPLIT
    default y

# 2 peripherale (lewa + prawa połówka)
config ZMK_SPLIT_BLE_CENTRAL_PERIPHERALS
    default 2

# 2 peripherale + 5 profili BT = 7
config BT_MAX_CONN
    default 7

config BT_MAX_PAIRED
    default 7

endif
